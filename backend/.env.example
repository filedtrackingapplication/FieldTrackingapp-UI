SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
DATABASE_URL=sqlite:///./field_tracking.db
DEBUG=true
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
UPLOAD_DIR=uploads

# Redis (optional — set REDIS_ENABLED=false to disable)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# DB connection pool (ignored for SQLite)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Location ingestion buffer
LOCATION_FLUSH_INTERVAL=2.0
LOCATION_BUFFER_MAX=200

# Rate limits
RATE_LIMIT_LOCATION=120/minute
RATE_LIMIT_DEFAULT=60/minute
